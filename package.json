{
  "name": "boxing-coach-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Boxing Coach with WebAssembly audio/video processing",
  "scripts": {
    "// ============ WASM ============": "",
    "build:wasm": "asc src/assembly/index.ts --outFile src/wasm/index.wasm",
    "watch:wasm": "asc src/assembly/index.ts --outFile src/wasm/index.wasm --watch",
    "clean:wasm": "rm -f src/wasm/index.wasm src/wasm/index.d.ts",

    "// ============ BACKEND ============": "",
    "dev:backend": "tsx watch server.ts",
    "build:backend": "tsc --project tsconfig.json --noEmit",

    "// ============ FRONTEND ============": "",
    "dev:frontend": "vite",
    "build:frontend": "npm run build:wasm && vite build",
    "preview:frontend": "vite preview",

    "// ============ FULL STACK ============": "",
    "dev": "concurrently --names \"WASM,BACKEND,FRONTEND\" npm:watch:wasm npm:dev:backend npm:dev:frontend",
    "build": "npm run build:wasm && npm run build:frontend && npm run build:backend",
    "start": "NODE_ENV=production tsx server.ts",
    "preview": "npm run preview:frontend",

    "// ============ UTILITIES ============": "",
    "clean": "rm -rf dist src/wasm/*.wasm",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit --skipLibCheck false",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cookie-session": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@assemblyscript/loader": "^0.28.9",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "assemblyscript": "^0.28.9",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
